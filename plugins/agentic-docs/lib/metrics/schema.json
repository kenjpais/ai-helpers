{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agentic-Docs Execution Metrics",
  "description": "Schema for metrics JSON files generated by agentic-docs commands",
  "type": "object",
  "required": [
    "command",
    "repository",
    "timestamp_start",
    "timestamp_end",
    "duration_ms",
    "result"
  ],
  "properties": {
    "command": {
      "type": "string",
      "description": "Command that was executed",
      "enum": [
        "agentic-docs:create",
        "agentic-docs:validate",
        "agentic-docs:evaluate"
      ]
    },
    "repository": {
      "type": "string",
      "description": "Absolute path to repository",
      "minLength": 1
    },
    "timestamp_start": {
      "type": "string",
      "description": "ISO 8601 timestamp when command started",
      "format": "date-time"
    },
    "timestamp_end": {
      "type": "string",
      "description": "ISO 8601 timestamp when command ended",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "number",
      "description": "Total duration in milliseconds",
      "minimum": 0
    },
    "primary_agent": {
      "type": "string",
      "description": "Primary agent name",
      "default": "Main Orchestrator"
    },
    "sub_agents": {
      "type": "array",
      "description": "Sub-agents spawned during execution",
      "items": {
        "type": "object",
        "required": ["agent_id", "agent_type", "timestamp"],
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Unique agent identifier"
          },
          "agent_type": {
            "type": "string",
            "description": "Type of agent",
            "enum": ["primary", "judge", "coding"]
          },
          "timestamp": {
            "type": "string",
            "description": "When agent was spawned",
            "format": "date-time"
          },
          "duration_ms": {
            "type": "number",
            "description": "Agent execution duration in milliseconds",
            "minimum": 0
          },
          "tools_used": {
            "type": "array",
            "description": "Tools used by this agent",
            "items": {"type": "string"}
          },
          "skills_used": {
            "type": "array",
            "description": "Skills used by this agent",
            "items": {"type": "string"}
          },
          "files_accessed": {
            "type": "array",
            "description": "Files accessed by this agent",
            "items": {"type": "string"}
          }
        }
      }
    },
    "tools_used": {
      "type": "object",
      "description": "Count of each tool used",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "skills_used": {
      "type": "object",
      "description": "Count of each skill used",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "data_sources": {
      "type": "array",
      "description": "Data sources accessed during execution",
      "items": {"type": "string"}
    },
    "files_created": {
      "type": "array",
      "description": "Files created during execution",
      "items": {"type": "string"}
    },
    "files_accessed": {
      "type": "array",
      "description": "Files read during execution",
      "items": {"type": "string"}
    },
    "data_flows": {
      "type": "array",
      "description": "Data flow between components",
      "items": {
        "type": "object",
        "required": ["source", "destination", "data_type", "timestamp"],
        "properties": {
          "source": {"type": "string"},
          "destination": {"type": "string"},
          "data_type": {"type": "string"},
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "result": {
      "type": "string",
      "description": "Overall result of command execution",
      "enum": ["PASS", "FAIL", "COMPLETED", "ERROR", "UNKNOWN"]
    },
    "details": {
      "type": "object",
      "description": "Command-specific result details",
      "additionalProperties": true
    }
  }
}
